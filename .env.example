# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# Timezone for date derivation (IANA name, e.g. America/New_York, Europe/London). Defaults to America/Denver if unset.
LOCAL_TZ=America/Denver

# Claude Code OAuth token (for VPS headless auth)
# Generate via: claude setup-token (on a machine with a browser)
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub personal access token (if needed for API access)
# GITHUB_TOKEN=

# Google Health OAuth client (for automations/scripts/google_health_*.py)
# Create OAuth client in Google Cloud Console; TOKEN_FILE is auto-written by google_health_auth.py
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_TOKEN_FILE=./config/google_health_tokens.json

# Trello inbox capture (for pfc-trello-inbox skill)
#
# IMPORTANT: This skill targets a REGULAR BOARD with one list — NOT Trello's
# built-in personal Inbox feature. The personal Inbox is architecturally
# separate and has NO public REST API. You must create a normal board with
# a list (e.g. board="Inbox", list="Inbox") and dictate to that list from
# your phone (one-tap pinned widget on Android, Shortcuts action on iOS).
#
# Setup (Trello unified API access with Power-Ups — the old trello.com/app-key
# page is deprecated and produces keys that won't pair with new tokens):
#   1. Go to https://trello.com/power-ups/admin
#   2. Create a Power-Up — any name (e.g. "Personal Inbox"), pick the
#      workspace your inbox board belongs to (the Power-Up needs workspace
#      access to read your boards). Leave iframe URL blank or use
#      https://example.com. You are not building a real Power-Up; it's
#      just the auth container.
#   3. Open the Power-Up → API Key tab → Generate a new API Key. Copy it
#      into TRELLO_API_KEY below.
#   4. On the SAME page, find the "Token" hyperlink (separate from the
#      "API Secret" — IGNORE the secret, it's only used for OAuth signing
#      which we don't do). Click "Token" → authorize → copy the long
#      string from the resulting page into TRELLO_API_TOKEN below. The
#      token MUST be issued from this Power-Up's API Key page so the
#      key/token pair validates together.
#   5. Find the inbox list ID. Use single-quoted curl ('single quotes' so
#      bash does not background on the & or expand $vars):
#        curl 'https://api.trello.com/1/members/me/boards?fields=name&key=KEY&token=TOKEN'
#      Pick the board id, then list its lists:
#        curl 'https://api.trello.com/1/boards/{boardId}/lists?fields=name&key=KEY&token=TOKEN'
#      Copy the list id into TRELLO_INBOX_LIST_ID below. The board id
#      itself is NOT needed — list ids are globally unique.
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_INBOX_LIST_ID=

# Trello dashboard board (for pfc-render-trello skill — Phase B1+)
# This is the same board that hosts your Inbox list. Get the board id with:
#   curl 'https://api.trello.com/1/lists/<TRELLO_INBOX_LIST_ID>?fields=idBoard&key=KEY&token=TOKEN'
# The render writes cards into the lists already created on this board (and
# creates any missing canonical lists at the bottom). The 📥 Inbox list is
# hard-excluded from the render.
TRELLO_DASHBOARD_BOARD_ID=
